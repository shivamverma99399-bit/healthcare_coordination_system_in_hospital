DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
DATABASE_URL=sqlite:///healthcare_system/db.sqlite3
DJANGO_ENABLE_DEMO_ACCOUNTS=0
GEMINI_ENABLED=0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=8
MAPMYINDIA_CLIENT_ID=
MAPMYINDIA_CLIENT_SECRET=
RUN_SEED_DATA=1
RUN_SEED_DEMO_ACCESS=0
